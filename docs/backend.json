
{
  "entities": {
    "Post": {
      "title": "Artifact",
      "description": "A forged item or chronicle in the arena.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "title": { "type": "string", "description": "Name of the Artifact" },
        "content": { "type": "string", "description": "Lore or description of the artifact." },
        "author": { "type": "string" },
        "avatarUrl": { "type": "string", "format": "uri" },
        "imageUrl": { "type": "string", "format": "uri" },
        "upvotes": { "type": "number" },
        "downvotes": { "type": "number" },
        "comments": { "type": "number" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "object" },
        "rarity": { "type": "string", "enum": ["Common", "Rare", "Epic", "Legendary"] },
        "affiliateLink": { "type": "string", "format": "uri", "description": "Loot drop link" },
        "aiResult": {
          "type": "object",
          "properties": {
            "relevanceScore": { "type": "number", "description": "Power Level Score" },
            "reasoning": { "type": "string", "description": "Appraisal reasoning" }
          }
        }
      }
    },
    "UserProfile": {
      "title": "Operator Profile",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "level": { "type": "number" },
        "karma": { "type": "number" },
        "inventory": { "type": "array", "items": { "type": "string" } },
        "bossKills": { "type": "number" },
        "totalDamageDealt": { "type": "number" },
        "heroClass": { "type": "string", "enum": ["Warrior", "Mage", "Rogue"] }
      }
    },
    "Monster": {
      "title": "Monster",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "hp": { "type": "number" },
        "maxHp": { "type": "number" },
        "atk": { "type": "number" },
        "level": { "type": "number" },
        "imageUrl": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "Item": {
      "title": "Item",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["Weapon", "Armor", "Material", "Relic"] },
        "rarity": { "type": "string", "enum": ["Common", "Rare", "Epic", "Legendary"] },
        "imageUrl": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/posts": {
      "schema": { "$ref": "#/entities/Post" },
      "description": "Arena artifact feed."
    },
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Operator profile data."
    },
    "/worldEvents/{eventId}": {
      "schema": { "$ref": "#/entities/WorldEvent" },
      "description": "Active and scheduled world boss events."
    }
  }
}
