
{
  "entities": {
    "Post": {
      "title": "Artifact",
      "description": "A forged item or chronicle in the arena.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "title": { "type": "string", "description": "Name of the Artifact" },
        "content": { "type": "string", "description": "Lore or description of the artifact." },
        "author": { "type": "string" },
        "avatarUrl": { "type": "string", "format": "uri" },
        "imageUrl": { "type": "string", "format": "uri" },
        "upvotes": { "type": "number" },
        "downvotes": { "type": "number" },
        "comments": { "type": "number" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "object" },
        "rarity": { "type": "string", "enum": ["Common", "Rare", "Epic", "Legendary"] },
        "aiResult": {
          "type": "object",
          "properties": {
            "relevanceScore": { "type": "number" },
            "reasoning": { "type": "string" }
          }
        }
      }
    },
    "UserProfile": {
      "title": "Operator Profile",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "level": { "type": "number" },
        "karma": { "type": "number" },
        "inventory": { "type": "array", "items": { "$ref": "#/entities/Item" } },
        "stash": { "type": "array", "items": { "$ref": "#/entities/Item" } },
        "equipped": {
            "type": "object",
            "properties": {
                "weapon": { "$ref": "#/entities/Item" },
                "armor": { "$ref": "#/entities/Item" }
            }
        },
        "potions": { "type": "number" },
        "heroClass": { "type": "string", "enum": ["Warrior", "Mage", "Rogue"] }
      }
    },
    "Item": {
      "title": "Loot Item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["Weapon", "Armor", "Material", "Relic", "Potion"] },
        "rarity": { "type": "string", "enum": ["Common", "Rare", "Epic", "Legendary"] },
        "imageUrl": { "type": "string" },
        "statBoost": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "github.com"]
  },
  "firestore": {
    "/posts": {
      "schema": { "$ref": "#/entities/Post" },
      "description": "Arena artifact feed."
    },
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Operator profile data."
    }
  }
}
