rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /posts/{postId} {
      allow read: if true;
      // This rule is temporarily open to allow for initial database seeding from the client.
      // For production, you should restrict this to authenticated users and run a separate seeding script:
      // allow create: if request.auth != null && request.auth.uid == request.resource.data.uid;
      allow create: if true;
      
      // Allow author to delete
      allow delete: if request.auth != null && request.auth.uid == resource.data.uid;
      // Allow any authenticated user to update (for voting)
      allow update: if request.auth != null;
    }
    match /challenges/{challengeId} {
      allow read: if true;
      // Allow seeding of challenges, but do not allow subsequent user modification.
      allow create: if true;
      allow update: if false;
      allow delete: if false;
    }
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      
      // Allow user to only access their own dashboard data
      match /dashboard/{document=**} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
