rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Arena artifacts (posts)
    match /posts/{postId} {
      allow read, write: if true;
    }

    // World Events and Super Boss raids
    match /worldEvents/{eventId} {
      allow read, write: if true;
    }

    // Quests (challenges)
    match /challenges/{challengeId} {
      allow read, write: if true;
    }

    // Operator Profiles
    match /users/{userId} {
      allow read, write: if true;
      
      // Encrypted Command Center data (Private)
      match /dashboard/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}