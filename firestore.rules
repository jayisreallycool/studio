rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Arena artifacts (posts)
    match /posts/{postId} {
      allow read: if true;
      // Allow creation for seeding and by authenticated users
      allow create: if true;
      // Allow author to delete their own artifacts
      allow delete: if request.auth != null && request.auth.uid == resource.data.uid;
      // Allow any authenticated user to update (for voting/interactions)
      allow update: if request.auth != null;
    }

    // World Events and Super Boss raids
    match /worldEvents/{eventId} {
      allow read: if true;
      // Allow seeding from client for prototype
      allow create: if true;
      // Allow authenticated operators to strike the boss
      allow update: if request.auth != null;
    }

    // Quests (challenges)
    match /challenges/{challengeId} {
      allow read: if true;
      allow create: if true; // Allow seeding
      allow update: if false;
      allow delete: if false;
    }

    // Operator Profiles
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      
      // Encrypted Command Center data
      match /dashboard/{document=**} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}